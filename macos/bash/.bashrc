
# Text editor
export EDITOR="code -w"

# Amazon Web Services profile
export AWS_PROFILE=default

export JAVA_HOME="/usr/local/lib/jdk8u192-b12/Contents/Home"

# PATH
export PATH="/usr/local/lib/jdk8u192-b12/Contents/Home/bin:/usr/local/lib/apache-maven-3.6.0/bin:$PATH"

# Aliases
alias did="vi +'normal Go' +'r!date' ~/Google\ Drive/aaa-notes/did.txt" 

