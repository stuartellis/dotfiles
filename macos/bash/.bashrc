
# Text editor
export EDITOR="nvim"

# Amazon Web Services profile
export AWS_PROFILE=default

export GITHUB_API_TOKEN="00fae5e9871df6d9c06b65230e4a6f16a9654310"

export JAVA_HOME="/usr/local/lib/jdk-11.0.1+13/Contents/Home"

# PATH
export PATH="$HOME/Library/Python/3.7/bin:/usr/local/nvim-osx64/bin:/usr/local/lib/jdk-11.0.1+13/Contents/Home/bin:/usr/local/lib/apache-maven-3.6.0/bin:$PATH"

# Aliases
alias n="nvim"
alias did="nvim +'normal Go' +'r!date' ~/Google\ Drive/aaa-notes/did.txt" 
alias p3="python3"
